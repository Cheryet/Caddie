# Caddie — Environment Variables
# Copy to .env and fill in values for local development.
# .env is gitignored. Never commit secrets.
# The Anthropic API key is intentionally NOT here — it lives as a Supabase
# secret and is only used by the analyze-swing Edge Function.
# See PROJECT_SPEC.md §23 for details.

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=

# RevenueCat
REVENUECAT_API_KEY_IOS=

# Sentry
SENTRY_DSN=

# Posthog
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# App
APP_ENV=development
